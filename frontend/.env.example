# --- Mode (optional) ---
# Unset: `next dev` uses local backend only; `next start` / production build uses NARRIA_BACKEND_URL.
# NARRIA_ENV=development   # force local backend even if NARRIA_BACKEND_URL is set
# NARRIA_ENV=production    # force external NARRIA_BACKEND_URL (for odd setups)

# --- Link to Express backend (set on Render / production; ignored during local `next dev`) ---
# Full URL, no trailing slash. Example: https://narria-api.onrender.com
NARRIA_BACKEND_URL=

# Optional: same URL as NARRIA_BACKEND_URL if you want the browser to call the API directly
# instead of via Next’s /api/narria rewrite. Leave unset to use the rewrite (recommended if CORS is fine).
# NEXT_PUBLIC_API_BASE_URL=

# Local dev only: port where Express listens if NARRIA_BACKEND_URL is unset (default 4000).
# Match backend/.env PORT.
# NARRIA_BACKEND_PORT=4000

# Next.js dev server port (optional; Next defaults to 3000).
# PORT=3000
