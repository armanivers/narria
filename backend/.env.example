# Copy to backend/.env (or use repo-root .env — see backend/src/loadEnv.js)

# --- Google Gemini (cartoon avatar after profile selfie) ---
# https://aistudio.google.com/app/apikey
# If logs show "suspended" or 403 Permission denied, create a new key or fix the Google Cloud project.
# ElevenLabs (custom_name / custom_front / subtitles) does NOT need Gemini.
GEMINI_API_KEY=

# Optional
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# GEMINI_CARTOON_PROMPT=Make a cartoon version of this kid in a friendly children's book style.

# --- ElevenLabs (two TTS clips per child: name only + front cover line) ---
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
# Voice id from https://elevenlabs.io/app/voice-library or your "My voices" list
ELEVENLABS_VOICE_ID=

# After a profile selfie (POST /profile/photo), the server always runs the post-upload job: ElevenLabs does not require GEMINI_API_KEY.
# ElevenLabs runs even if Gemini/cartoon fails or is disabled — writes per user:
#   backend/public/assets/audio/personalized/users/<parentId>/custom_name.mp3   — spoken text is exactly the child's name (e.g. "Ari")
#   backend/public/assets/audio/personalized/users/<parentId>/custom_front.mp3 — "Hello, Ari. Welcome to the world of dragons. Uh, buckle down for the journey"
#   backend/public/assets/audio/personalized/users/<parentId>/custom_front.json — subtitles for custom_front (generated from MP3 duration; default line matches two-segment template)
#
# POST /audio/elevenlabs/welcome { childName, parentId? } (or legacy `name`) generates the same two files.

# Optional: override the long line only; use {name} as placeholder for the child's name
# ELEVENLABS_CUSTOM_FRONT_TEMPLATE=Hello, {name}. Welcome to the world of dragons. Uh, buckle down for the journey

# Optional TTS model (default: eleven_multilingual_v2)
# ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# --- books.json audio ---
# Each clip is { "src": "filename.mp3", "startDelayMs": 0, "custom": false } or an array of those.
# If "custom": true, src is only the filename; resolved to /assets/audio/personalized/users/<parentId>/filename.mp3
# when GET /books/:bookId or /books/:bookId/pages/:n includes ?parentId=<sanitized parent id> (story app sends this).
# Subtitles: same folder, filename.mp3 → filename.json (frontend loads from resolved audio URL).

# --- n8n (optional) — after each saved story outcome, POST the same JSON body to this webhook ---
# N8N_STORY_OUTCOME_WEBHOOK_URL=https://your-n8n.example.com/webhook/story-outcome
